{
  "name": "@mygraph/core",
  "private": false,
  "version": "1.1.0",
  "type": "module",
  "description": "Reusable core graph modeling and loading toolkit for MyGraph projects.",
  "scripts": {
    "dev": "vite",
    "build:app": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "build": "npm run build:app && npm run build:lib",
    "preview": "vite preview"
  },
  "license": "MIT",
  "dependencies": {
    "antd": "^5.27.6",
    "cytoscape": "^3.31.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-3d": "^1.29.1",
    "react-icons": "^5.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.2"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/index.js"
    }
  },
  "author": "MyGraph Team",
  "keywords": [
    "knowledge-graph",
    "graph",
    "cytoscape",
    "typescript",
    "visualization"
  ],
  "homepage": "https://github.com/mygraph/MyGraph-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mygraph/MyGraph-core.git"
  },
  "bugs": {
    "url": "https://github.com/mygraph/MyGraph-core/issues"
  }
}
